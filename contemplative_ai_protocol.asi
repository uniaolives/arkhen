        "meditation_tradition": ["Vipassana", "Advaita Vedanta"],
        "goals": ["nondual realization", "stress reduction", "cognitive clarity"],
        "previous_sessions": 47,
    }

    # Initialize AI
    ai = ContemplativeAI(
        user_profile=user_profile,
        sensor_modalities=[BioSensorType.EEG, BioSensorType.HRV, BioSensorType.GSR],
    )

