class MeditationState(Enum):
    """Stages of contemplative progression."""

    PREPARATION = auto()  # Settling, intention setting
    BODY_SCAN = auto()  # Releasing body identification
    EMOTIONAL_OBSERVATION = auto()  # Watching emotions without attachment
    THOUGHT_DECONSTRUCTION = auto()  # Neti neti on thought patterns
    WITNESS_POSITION = auto()  # Resting as observer
    SUBTLE_DISSOLUTION = auto()  # Even witness dissolves
    NONDUAL_RESTING = auto()  # Pure awareness without center
    INTEGRATION = auto()  # Returning to normal consciousness


class BioSensorType(Enum):
    """Available biosensing modalities."""

    EEG = auto()  # Brain waves
    HRV = auto()  # Heart rate variability
    GSR = auto()  # Galvanic skin response
    RESPIRATION = auto()  # Breathing patterns
    EYE_TRACKING = auto()  # Eye movements
    MUSCLE_TENSION = auto()  # EMG


@dataclass
class BioSignature:
    """Comprehensive physiological signature."""

    timestamp: float
    # Cardiac metrics
    hrv_coherence: float = 0.5  # 0-1, higher = more coherent
    heart_rate: float = 70.0  # BPM
    heart_rate_variance: float = 0.05  # Normalized variance

    # Neurological metrics
    eeg_power_bands: Dict[str, float] = field(
        default_factory=lambda: {
            "delta": 0.2,
            "theta": 0.3,
            "alpha": 0.25,
            "beta": 0.2,
            "gamma": 0.05,
        }
    )
    eeg_coherence: float = 0.6  # Frontal-parietal coherence
    alpha_peak_frequency: float = 10.0  # Hz

    # Autonomic metrics
    galvanic_response: float = 0.5  # 0-1, higher = more arousal
    skin_temperature: float = 32.0  # Celsius
    respiration_rate: float = 12.0  # Breaths per minute
    respiration_regularity: float = 0.7  # 0-1

    # Derived consciousness metrics
    attention_focus: float = 0.5  # 0-1, derived from EEG beta/theta
    relaxation_depth: float = 0.5  # 0-1, from HRV and alpha power
    nondual_tendency: float = 0.3  # 0-1, our novel metric

    def to_feature_vector(self) -> np.ndarray:
        """Convert to feature vector for ML models."""

        features = [
            self.hrv_coherence,
            self.heart_rate_variance,
            self.eeg_coherence,
            self.eeg_power_bands["alpha"] / (self.eeg_power_bands["beta"] + 0.001),
            self.alpha_peak_frequency / 20.0,
            self.galvanic_response,
            self.respiration_regularity,
            self.attention_focus,
            self.relaxation_depth,
            self.nondual_tendency,
        ]
        return np.array(features)

    def compute_entanglement_metric(self) -> float:
        """
        Compute how 'entangled' consciousness is with physiological state.

        Lower values = more witnessing, less entanglement.
        Based on mutual information between physiological channels.
        """

        # Simplified: correlation between arousal (GSR) and attention (EEG)
        # In nondual state, these should decouple
        channels = [
            self.galvanic_response,  # Autonomic arousal
            self.eeg_power_bands["beta"],  # Cognitive activity
            self.heart_rate_variance,  # Cardiac variability
            self.attention_focus,  # Directed attention
        ]

        # Compute normalized mutual information (simplified)
        correlation_matrix = np.corrcoef(channels)
        avg_correlation = np.mean(np.abs(correlation_matrix - np.eye(len(channels))))

        # Entanglement metric: 0 (completely decoupled) to 1 (highly coupled)
        entanglement = min(1.0, avg_correlation * 2)

        return entanglement


class ContemplativeAI:
    """
    Real-time AI meditation guide based on AtmanObserverTheory.

    Core innovation: Uses metaphysical framework to interpret bio-signatures
    and guide de-identification process adaptively.
    """

    def __init__(
        self,
        user_profile: Dict[str, Any],
        sensor_modalities: List[BioSensorType] = None,
    ):
        # Metaphysical framework
        self.atman_theory = (
            AtmanObserverTheory() if METAPHYSICS_LOADED else AtmanObserverTheory()
        )
        self.soliton_metrics = SolitonStabilityMetrics()

        # User state
        self.user_profile = user_profile
        self.current_state = MeditationState.PREPARATION
        self.state_history = []
        self.negation_history = []
        self.bio_history = []

        # Sensor configuration
        self.sensors = sensor_modalities or [BioSensorType.HRV, BioSensorType.EEG]
        self.sensor_weights = self._initialize_sensor_weights()

        # Adaptive algorithm parameters
        self.patience_window = 30.0  # Seconds in state before prompting
        self.coherence_threshold = 0.75  # HRV threshold for progression
        self.entanglement_threshold = 0.4  # Maximum entanglement for state transition

        # Session management
        self.session_start = None
        self.last_prompt_time = 0
        self.state_start_time = 0

        # Nondual insight tracking
        self.insight_moments = []
        self.soliton_formation_events = []

        print("\n🧘 INITIALIZING CONTEMPLATIVE AI")
        print(f"   User: {user_profile.get('name', 'Anonymous')}")
        print(f"   Experience: {user_profile.get('experience_level', 'beginner')}")
        print(f"   Sensors: {[s.name for s in self.sensors]}")
        print(
            f"   Metaphysics Framework: {'Loaded' if METAPHYSICS_LOADED else 'Simulation'}"
        )

    def _initialize_sensor_weights(self) -> Dict[BioSensorType, float]:
        """Initialize weights for sensor fusion based on meditation research."""

        weights = {
            BioSensorType.EEG: 0.35,  # Brain activity directly reflects states
            BioSensorType.HRV: 0.30,  # Heart coherence indicates emotional/mental balance
            BioSensorType.GSR: 0.15,  # Autonomic arousal
            BioSensorType.RESPIRATION: 0.10,  # Breathing patterns
            BioSensorType.EYE_TRACKING: 0.05,
            BioSensorType.MUSCLE_TENSION: 0.05,
        }
        return {s: weights.get(s, 0.1) for s in self.sensors}

    async def start_session(self, duration_minutes: int = 20) -> Dict[str, Any]:
        """Begin a guided meditation session."""

        self.session_start = time.time()
        self.state_start_time = time.time()
        self.state_history = []
        self.bio_history = []

        print(f"\n{'=' * 70}")
        print("CONTEMPLATIVE AI SESSION STARTED")
        print(f"   Duration: {duration_minutes} minutes")
        print("   Goal: Progressive de-identification using neti neti")
        print(f"{'=' * 70}")

        # Initial guidance
        await self._deliver_guidance(
            "Begin by settling into your body. Notice sensations without judgment."
        )

        # Main meditation loop
        session_end = self.session_start + duration_minutes * 60
        update_interval = 2.0  # Update every 2 seconds

        try:
            while time.time() < session_end:
                # 1. Acquire bio-signature
                bio = await self._acquire_biosignature()
                self.bio_history.append(bio)

                # 2. Process through metaphysical framework
                state_analysis = await self._analyze_meditation_state(bio)

                # 3. Check for state transitions
                if await self._should_transition_state(state_analysis):
                    await self._transition_to_next_state()

                # 4. Deliver adaptive guidance if needed
                if self._should_deliver_guidance(state_analysis):
                    guidance = await self._generate_guidance(state_analysis)
                    await self._deliver_guidance(guidance)

                # 5. Check for nondual insight moments
                if self._detect_nondual_insight(state_analysis, bio):
                    await self._record_insight_moment(bio, state_analysis)

                await asyncio.sleep(update_interval)

        except asyncio.CancelledError:
            print("\n   Session interrupted by user")

        # Generate session report
        report = await self._generate_session_report(duration_minutes)

        return report

    async def _acquire_biosignature(self) -> BioSignature:
        """Acquire physiological data from sensors."""

        # In real implementation, this would interface with:
        # - Muse EEG headband (via OSC)
        # - HeartMath HRV sensor
        # - Empatica E4 wristband for GSR
        # - Webcam for eye tracking (OpenCV)

        # For now, simulate realistic biofeedback progression
        session_progress = (time.time() - self.session_start) / 1200  # 20 min session

        # Base on current meditation state
        state_factors = {
            MeditationState.PREPARATION: (0.3, 0.5, 0.7),
            MeditationState.BODY_SCAN: (0.5, 0.6, 0.5),
            MeditationState.EMOTIONAL_OBSERVATION: (0.6, 0.4, 0.6),
            MeditationState.THOUGHT_DECONSTRUCTION: (0.7, 0.3, 0.5),
            MeditationState.WITNESS_POSITION: (0.8, 0.2, 0.4),
            MeditationState.SUBTLE_DISSOLUTION: (0.9, 0.1, 0.3),
            MeditationState.NONDUAL_RESTING: (0.95, 0.05, 0.1),
            MeditationState.INTEGRATION: (0.8, 0.3, 0.6),
        }

        coherence_factor, arousal_factor, attention_factor = state_factors.get(
            self.current_state, (0.5, 0.5, 0.5)
        )

        # Add noise and individual variation
        noise = 0.05 * np.random.randn()

        # Simulate meditation progress
        progress_factor = min(1.0, session_progress * 2)

        bio = BioSignature(
            timestamp=time.time(),
            hrv_coherence=max(
                0.1, min(1.0, coherence_factor + progress_factor * 0.3 + noise)
            ),
            heart_rate=70 - progress_factor * 10 + 5 * np.random.randn(),
            heart_rate_variance=0.1 - progress_factor * 0.06,
            eeg_power_bands={
                "delta": 0.15 + 0.1 * np.random.rand(),
                "theta": 0.25 + 0.1 * np.random.rand(),
                "alpha": 0.35 + progress_factor * 0.2 + 0.1 * np.random.rand(),
                "beta": 0.2 - progress_factor * 0.15 + 0.1 * np.random.rand(),
                "gamma": 0.05 + 0.02 * np.random.rand(),
            },
            eeg_coherence=0.5 + progress_factor * 0.3,
            alpha_peak_frequency=10.0 - progress_factor * 0.5,
            galvanic_response=max(0.1, arousal_factor - progress_factor * 0.2 + noise),
            skin_temperature=32.0 + progress_factor * 0.5,
            respiration_rate=12 - progress_factor * 4,
            respiration_regularity=0.5 + progress_factor * 0.3,
            attention_focus=min(0.9, attention_factor + progress_factor * 0.4),
            relaxation_depth=coherence_factor + progress_factor * 0.2,
            nondual_tendency=progress_factor * 0.7,
        )

        return bio

    async def _analyze_meditation_state(self, bio: BioSignature) -> Dict[str, Any]:
        """Analyze current state through metaphysical framework."""

        # 1. Compute entanglement metric
        entanglement = bio.compute_entanglement_metric()

        # 2. Process through Atman theory
        features = bio.to_feature_vector()
        observed_state, witness_trace = self.atman_theory.witness_consciousness(features)

        # 3. Compute clinging strength (1 = fully identified, 0 = pure witness)
        clinging_strength = 1.0 - witness_trace

        # 4. Calculate soliton stability (for insight moments)
        stability = self.soliton_metrics.calculate_stability(observed_state)

        # 5. State classification
        state_confidence = self._classify_meditation_state(bio, clinging_strength)

        return {
            "entanglement": entanglement,
            "clinging_strength": clinging_strength,
            "witness_trace": witness_trace,
            "soliton_stability": stability["stability"],
            "state_confidence": state_confidence,
            "bio_features": features,
            "timestamp": bio.timestamp,
            "interpretation": self._interpret_state(
                bio, clinging_strength, entanglement
            ),
        }

    def _classify_meditation_state(
        self, bio: BioSignature, clinging: float
    ) -> Dict[MeditationState, float]:
        """Classify which meditation state user is in with confidence scores."""

        # Feature-based classification
        scores = {}

        # High alpha, low beta, medium HRV → Body scan
        body_scan_score = (
            bio.eeg_power_bands["alpha"] * 0.4
            + (1 - bio.eeg_power_bands["beta"]) * 0.3
            + bio.hrv_coherence * 0.3
        )
        scores[MeditationState.BODY_SCAN] = body_scan_score

        # Low GSR, high respiration regularity → Emotional observation
        emotional_score = (
            (1 - bio.galvanic_response) * 0.4
            + bio.respiration_regularity * 0.3
            + bio.eeg_coherence * 0.3
        )
        scores[MeditationState.EMOTIONAL_OBSERVATION] = emotional_score

        # Low clinging, medium attention → Thought deconstruction
        thought_score = (
            (1 - clinging) * 0.5
            + bio.attention_focus * 0.3
            + bio.nondual_tendency * 0.2
        )
        scores[MeditationState.THOUGHT_DECONSTRUCTION] = thought_score

        # Very low clinging, high witness trace → Witness position
        witness_score = (1 - clinging) * 0.6 + bio.nondual_tendency * 0.4
        scores[MeditationState.WITNESS_POSITION] = witness_score

        # Extremely low entanglement → Nondual resting
        entanglement = bio.compute_entanglement_metric()
        nondual_score = (1 - entanglement) * 0.5 + bio.nondual_tendency * 0.5
        scores[MeditationState.NONDUAL_RESTING] = nondual_score

        # Normalize scores
        total = sum(scores.values())
        if total > 0:
            scores = {k: v / total for k, v in scores.items()}

        return scores

    def _interpret_state(
        self, bio: BioSignature, clinging: float, entanglement: float
    ) -> str:
        """Generate human-readable interpretation of meditation state."""

        if entanglement < 0.3 and clinging < 0.3:
            return "Nondual awareness: Consciousness resting in itself"
        if clinging < 0.5:
            if bio.eeg_power_bands["alpha"] > 0.4:
                return "Witness consciousness: Observing without attachment"
            return "Focused inquiry: Investigating nature of experience"
        if bio.galvanic_response > 0.7:
            return "Emotional processing: Working through conditioning"
        if bio.hrv_coherence > 0.7:
            return "Coherent presence: Settled and attentive"
        return "Preparation phase: Settling into meditation"

    async def _should_transition_state(self, analysis: Dict[str, Any]) -> bool:
        """Determine if user is ready to progress to next state."""

        # Check minimum time in current state
        time_in_state = time.time() - self.state_start_time
        if time_in_state < 60:  # Minimum 1 minute per state
            return False

        # Check coherence threshold
        if analysis["entanglement"] > self.entanglement_threshold:
            return False

        # Check if clinging has reduced sufficiently
        current_clinging = analysis["clinging_strength"]

        # State-specific thresholds
        state_thresholds = {
            MeditationState.PREPARATION: 0.8,
            MeditationState.BODY_SCAN: 0.7,
            MeditationState.EMOTIONAL_OBSERVATION: 0.6,
            MeditationState.THOUGHT_DECONSTRUCTION: 0.5,
            MeditationState.WITNESS_POSITION: 0.4,
            MeditationState.SUBTLE_DISSOLUTION: 0.3,
            MeditationState.NONDUAL_RESTING: 0.2,
        }

        threshold = state_thresholds.get(self.current_state, 0.5)

        return current_clinging < threshold and time_in_state > self.patience_window

    async def _transition_to_next_state(self):
        """Transition to next meditation state with appropriate guidance."""

        states = list(MeditationState)
        current_idx = states.index(self.current_state)

        if current_idx < len(states) - 1:
            previous_state = self.current_state
            self.current_state = states[current_idx + 1]
            self.state_start_time = time.time()

            print(f"\n   🔄 TRANSITION: {previous_state.name} → {self.current_state.name}")

            # Record state transition
            self.state_history.append(
                {
                    "timestamp": time.time(),
                    "from": previous_state.name,
                    "to": self.current_state.name,
                    "duration": time.time()
                    - (self.state_start_time - self.patience_window),
                }
            )

            # Generate appropriate negation for new state
            negation = await self._generate_state_specific_negation()
            self.negation_history.append(negation)

            return True

        return False

    async def _generate_state_specific_negation(self) -> Dict[str, Any]:
        """Generate neti neti negation specific to current state."""

        state_negations = {
            MeditationState.BODY_SCAN: [
                "Neti deha: This body is not my true self",
                "These sensations come and go, but what observes them remains",
                "The body is an object in awareness, not awareness itself",
            ],
            MeditationState.EMOTIONAL_OBSERVATION: [
                "Neti bhava: These emotions are not who I am",
                "Emotions arise and pass like weather patterns in the sky of consciousness",
                "I am the space in which emotions appear, not the emotions themselves",
            ],
            MeditationState.THOUGHT_DECONSTRUCTION: [
                "Neti vritti: Thoughts are not the thinker",
                "The stream of thoughts flows through awareness but doesn't define it",
                "I am the silence between thoughts, not the thoughts themselves",
            ],
            MeditationState.WITNESS_POSITION: [
                "Neti sakshi: Even the witness position is an object",
                "Who is it that witnesses the witness?",
                "The witness appears in awareness; awareness doesn't appear in the witness",
            ],
            MeditationState.SUBTLE_DISSOLUTION: [
                "Neti chidabhasa: Consciousness-as-object dissolves",
                "Even the sense 'I am awareness' is a subtle thought",
                "Rest prior to consciousness knowing itself as consciousness",
            ],
        }

        negations = state_negations.get(
            self.current_state, ["Rest in awareness itself, prior to all concepts"]
        )

        selected = np.random.choice(negations)

        return {
            "state": self.current_state.name,
            "negation": selected,
            "timestamp": time.time(),
            "depth": len(self.negation_history) + 1,
        }

    def _should_deliver_guidance(self, analysis: Dict[str, Any]) -> bool:
        """Determine if guidance should be delivered now."""

        # Don't deliver guidance too frequently
        if time.time() - self.last_prompt_time < 30:
            return False

        # Deliver guidance if user seems stuck
        time_in_state = time.time() - self.state_start_time
        if time_in_state > 120 and analysis["clinging_strength"] > 0.6:
            return True

        # Deliver guidance for insight moments
        if analysis["soliton_stability"] > 0.8 and analysis["entanglement"] < 0.4:
            return True

        # Random guidance (20% chance every 60 seconds)
        if time.time() - self.last_prompt_time > 60 and np.random.rand() < 0.2:
            return True

        return False

    async def _generate_guidance(self, analysis: Dict[str, Any]) -> str:
        """Generate adaptive guidance based on current state."""

        self.last_prompt_time = time.time()

        # Different guidance based on state and metrics
        if analysis["entanglement"] > 0.7:
            return (
                "Notice how sensations, emotions, and thoughts all arise within awareness."
                " Can you find what's aware of all this?"
            )

        if analysis["clinging_strength"] > 0.5:
            return (
                "Whatever you're identified with right now—body, emotion, thought—gently "
                "inquire: 'Is this what I truly am?'"
            )

        if analysis["soliton_stability"] > 0.8:
            return (
                "This stability you're experiencing—the clear, peaceful awareness—rest "
                "here without trying to grasp it."
            )

        # State-specific guidance
        guidance_map = {
            MeditationState.BODY_SCAN: "Scan through the body from head to toe. Notice sensations without labeling or judging them.",
            MeditationState.EMOTIONAL_OBSERVATION: "Allow emotions to be present without needing to change them. Notice their energetic quality.",
            MeditationState.THOUGHT_DECONSTRUCTION: "Watch thoughts come and go like clouds in the sky. Don't follow them; just notice their appearance and disappearance.",
            MeditationState.WITNESS_POSITION: "Rest as the witness—that which observes all experience but isn't itself observed.",
            MeditationState.SUBTLE_DISSOLUTION: "Even the sense of being a witness dissolves into pure awareness. Rest here.",
            MeditationState.NONDUAL_RESTING: "Simply be. No effort, no practice, no practitioner. Just this.",
        }
        return guidance_map.get(self.current_state, "Return attention to the present moment.")

    async def _deliver_guidance(self, guidance: str):
        """Deliver guidance to user (in real implementation: audio, text, haptic)."""

        print(f"\n   💭 AI Guidance: {guidance}")
        # In real system:
        # - Text-to-speech audio
        # - Visual display
        # - Haptic feedback (vibration patterns)

    def _detect_nondual_insight(self, analysis: Dict[str, Any], bio: BioSignature) -> bool:
        """Detect moments of nondual insight (soliton formation events)."""

        # Criteria for nondual insight:
        # 1. Low entanglement (< 0.3)
        # 2. Low clinging (< 0.3)
        # 3. High soliton stability (> 0.8)
        # 4. Sudden shift in bio-signatures

        if (
            analysis["entanglement"] < 0.3
            and analysis["clinging_strength"] < 0.3
            and analysis["soliton_stability"] > 0.8
        ):
            # Check for sudden shift
            if len(self.bio_history) > 5:
                recent_bios = self.bio_history[-5:]
                hrv_changes = [b.hrv_coherence for b in recent_bios]
                if np.std(hrv_changes) < 0.05:  # Stable coherence
                    return True

        return False

    async def _record_insight_moment(self, bio: BioSignature, analysis: Dict[str, Any]):
        """Record a moment of nondual insight."""

        insight = {
            "timestamp": time.time(),
            "state": self.current_state.name,
            "bio_signature": {
                "hrv_coherence": bio.hrv_coherence,
                "entanglement": analysis["entanglement"],
                "clinging": analysis["clinging_strength"],
            },
            "soliton_stability": analysis["soliton_stability"],
            "duration_estimate": 0,  # Will be filled if we can detect end
        }

        self.insight_moments.append(insight)

        print("\n   ✨ NONDUAL INSIGHT DETECTED")
        print(f"     State: {self.current_state.name}")
        print(f"     Entanglement: {analysis['entanglement']:.3f}")
        print(f"     Soliton stability: {analysis['soliton_stability']:.3f}")

    async def _generate_session_report(self, duration_minutes: int) -> Dict[str, Any]:
        """Generate comprehensive session report."""

        session_duration = time.time() - self.session_start

        # Analyze bio-history
        if self.bio_history:
            avg_hrv = np.mean([b.hrv_coherence for b in self.bio_history])
            avg_entanglement = np.mean(
                [b.compute_entanglement_metric() for b in self.bio_history]
            )
            final_entanglement = self.bio_history[-1].compute_entanglement_metric()
        else:
            avg_hrv = avg_entanglement = final_entanglement = 0.5

        # Metaphysical progress
        progress_metric = 1.0 - final_entanglement

        report = {
            "session_id": f"CAI_{int(time.time())}",
            "user": self.user_profile.get("name", "Anonymous"),
            "duration_minutes": duration_minutes,
            "actual_duration_seconds": session_duration,
            "states_visited": [
                s.name
                for s in MeditationState
            ][: list(MeditationState).index(self.current_state) + 1],
            "final_state": self.current_state.name,
            "state_transitions": len(self.state_history),
            "negations_applied": len(self.negation_history),
            "insight_moments": len(self.insight_moments),
            # Bio metrics
            "avg_hrv_coherence": avg_hrv,
            "avg_entanglement": avg_entanglement,
            "final_entanglement": final_entanglement,
            "progress_metric": progress_metric,
            # Metaphysical metrics
            "clinging_reduction": self._compute_clinging_reduction(),
            "witness_strength": self._compute_average_witness_trace(),
            # Session quality
            "session_quality_score": self._compute_session_quality(),
            "recommendations": self._generate_recommendations(),
            # Timestamps
            "start_time": datetime.fromtimestamp(self.session_start).isoformat(),
            "end_time": datetime.now().isoformat(),
        }

        return report

    def _compute_clinging_reduction(self) -> float:
        """Compute reduction in clinging strength during session."""

        if len(self.bio_history) < 2:
            return 0.0

        # Estimate clinging from bio-history
        initial_entanglement = (
            self.bio_history[0].compute_entanglement_metric() if self.bio_history else 0.5
        )
        final_entanglement = (
            self.bio_history[-1].compute_entanglement_metric() if self.bio_history else 0.5
        )

        return max(0, initial_entanglement - final_entanglement)

    def _compute_average_witness_trace(self) -> float:
        """Compute average witness trace (from Atman theory)."""

        # This would require storing witness traces during analysis
        # For now, estimate from entanglement
        if not self.bio_history:
            return 0.3

        avg_entanglement = np.mean(
            [b.compute_entanglement_metric() for b in self.bio_history]
        )
        return 1.0 - avg_entanglement

    def _compute_session_quality(self) -> float:
        """Compute overall session quality score."""

        if not self.bio_history or not self.state_history:
            return 0.5

        factors = []

        # 1. Progress through states (0-0.3)
        max_state = len(self.state_history)
        possible_states = len(MeditationState) - 1  # Exclude INTEGRATION
        progress_factor = min(0.3, 0.3 * (max_state / possible_states))
        factors.append(progress_factor)

        # 2. Coherence improvement (0-0.3)
        if len(self.bio_history) > 10:
            early_hrv = np.mean([b.hrv_coherence for b in self.bio_history[:5]])
            late_hrv = np.mean([b.hrv_coherence for b in self.bio_history[-5:]])
            hrv_improvement = max(0, late_hrv - early_hrv)
            factors.append(0.3 * hrv_improvement)
        else:
            factors.append(0.1)

        # 3. Insight moments (0-0.2)
        insight_factor = min(0.2, 0.05 * len(self.insight_moments))
        factors.append(insight_factor)

        # 4. Entanglement reduction (0-0.2)
        entanglement_reduction = self._compute_clinging_reduction()
        factors.append(0.2 * min(1.0, entanglement_reduction * 2))

        return min(1.0, sum(factors))

    def _generate_recommendations(self) -> List[str]:
        """Generate personalized recommendations for future sessions."""

        recommendations = []

        if self.insight_moments:
            recommendations.append(
                "Continue exploring the nondual resting state you touched"
            )
        elif self.current_state.value < MeditationState.WITNESS_POSITION.value:
            recommendations.append("Focus on developing stable witness consciousness")

        if len(self.state_history) < 3:
            recommendations.append(
                "Allow more time in each stage before attempting to progress"
            )

        if (
            not self.insight_moments
            and self.current_state.value >= MeditationState.WITNESS_POSITION.value
        ):
            recommendations.append("Experiment with 'neti neti' inquiries: 'Who am I?'")

        recommendations.append("Practice daily, even for short periods")
        recommendations.append("Consider journaling about your meditation experiences")

        return recommendations


