    )
    print(f"   Insight Moments: {report['insight_moments']}")

    print("\n🧬 Bio Metrics:")
    print(f"   Avg HRV Coherence: {report['avg_hrv_coherence']:.3f}")
    print(f"   Final Entanglement: {report['final_entanglement']:.3f}")
    print(f"   Clinging Reduction: {report['clinging_reduction']:.3f}")

    print("\n🧠 Metaphysical Progress:")
    print(f"   Progress Metric: {report['progress_metric']:.3f}")
    print(f"   Witness Strength: {report['witness_strength']:.3f}")
    print(f"   Session Quality: {report['session_quality_score']:.3f}")

    print("\n💡 Recommendations:")
