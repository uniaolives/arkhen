@@ -0,0 +1,40 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <linux/module.h>
+#include <linux/kernel.h>
+#include <linux/fs.h>
+
+#define DEVICE_NAME "tzinor"
+
+static int tzinor_open(struct inode *inode, struct file *file) {
+    return 0;
+}
+
+static struct file_operations fops = {
+    .open = tzinor_open,
+};
+
+static int __init tzinor_init(void) {
+    register_chrdev(242, DEVICE_NAME, &fops);
+    pr_info("Arkhe(L): Tzinor Bridge driver initialized.\n");
+    return 0;
+}
+
+static void __exit tzinor_exit(void) {
+    unregister_chrdev(242, DEVICE_NAME);
+}
+
+module_init(tzinor_init);
+module_exit(tzinor_exit);
+
+MODULE_LICENSE("GPL");
+MODULE_DESCRIPTION("Tzinor Bridge Driver");
+